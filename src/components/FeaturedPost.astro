---
interface Props {
  title: string;
  date: Date;
  slug: string;
  categories?: string[];
  excerpt?: string;
  image?: string;
}

const { title, date, slug, categories = [], excerpt, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const category = categories[0] || 'Post';
---

<a href={`/posts/${slug}/`} class="hero-card group block">
  <div class="hero-card-inner">
    <!-- Text side -->
    <div class="hero-text">
      <div class="hero-cat">{category}</div>
      <div class="hero-divider"></div>
      <h2 class="hero-title">{title}</h2>
      {excerpt && <p class="hero-subtitle">{excerpt}</p>}
      <div class="hero-date">{formattedDate}</div>
    </div>

    <!-- Art side -->
    <div class="hero-art">
      {image ? (
        <img src={image} alt="" loading="eager" />
      ) : (
        <div class="hero-art-placeholder">
          <span>{category}</span>
        </div>
      )}
      <div class="hero-art-fade"></div>
    </div>
  </div>
</a>

<style>
  .hero-card-inner {
    background: var(--color-ink);
    border-radius: 12px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    min-height: 300px;
    position: relative;
  }

  @media (min-width: 768px) {
    .hero-card-inner {
      grid-template-columns: 1fr 1fr;
      min-height: 420px;
    }
  }

  .hero-text {
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .hero-text {
      padding: 56px 52px;
    }
  }

  .hero-cat {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-style: italic;
    color: var(--color-amber);
    margin-bottom: 20px;
  }

  .hero-divider {
    width: 48px;
    height: 3px;
    background: var(--color-amber);
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 28px;
    line-height: 1.1 !important;
    color: var(--color-ivory);
    margin-bottom: 16px;
    transition: color 0.3s;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 44px;
    }
  }

  .group:hover .hero-title {
    color: var(--color-amber);
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 24px;
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: 18px;
    }
  }

  .hero-date {
    font-family: var(--font-body);
    font-size: 13px;
    color: #666;
  }

  .hero-art {
    position: relative;
    overflow: hidden;
    display: none;
  }

  @media (min-width: 768px) {
    .hero-art {
      display: block;
    }
  }

  .hero-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.7s;
  }

  .group:hover .hero-art img {
    transform: scale(1.02);
  }

  .hero-art-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-forest-dark);
  }

  .hero-art-placeholder span {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 48px;
    color: var(--color-ivory);
    opacity: 0.08;
  }

  .hero-art-fade {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right,
      var(--color-ink) 0%,
      rgba(26,26,24,0.7) 35%,
      rgba(26,26,24,0) 70%
    );
    pointer-events: none;
  }
</style>
