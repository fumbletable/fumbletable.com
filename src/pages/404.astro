---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — Fumble Table">
  <div class="max-w-[var(--width-content)] mx-auto px-[var(--pad-side)] py-[120px] text-center">
    <p class="text-[80px] leading-none font-[var(--font-display)] font-900 text-amber mb-[16px]">404</p>
    <h1 class="text-[28px] font-[var(--font-display)] font-700 mb-[12px]">Critical Fumble</h1>
    <p class="text-muted text-[17px] mb-[40px]">You rolled a 1 on your navigation check. This page doesn't exist.</p>
    <a href="/" class="inline-block px-[24px] py-[10px] bg-forest text-ivory rounded-[8px] font-[var(--font-body)] text-[15px] font-600 hover:bg-forest-light transition-colors">Back to the Table</a>
  </div>
</Base>
